# API 키는 .env 파일에 저장하고 git에 올리지 마세요.
# 이 파일을 복사해 .env 로 저장한 뒤 키를 채우세요.

# YouTube Data API v3 (https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Supabase PostgreSQL (SQL Editor에서 supabase_schema.sql 실행 후 연결)
# 비밀번호에 ! 등 특수문자 있으면 URL 인코딩 (예: ! → %21)
# SUPABASE_DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-0-xxx.pooler.supabase.com:6543/postgres

# 선택: 기타 플랫폼 API 키
# INSTAGRAM_ACCESS_TOKEN=
# TIKTOK_ACCESS_TOKEN=
