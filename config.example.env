# API 키는 .env 파일에 저장하고 git에 올리지 마세요.
# 이 파일을 복사해 .env 로 저장한 뒤 키를 채우세요.

# YouTube Data API v3 (https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Supabase PostgreSQL — 자세한 설명: docs/supabase_connection.md
#
# Transaction pooler (서버리스·짧은 연결, 포트 6543)
# SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
#
# Direct (지속 연결·포트 5432, 사용자명은 postgres 단일)
# SUPABASE_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# 선택: 기타 플랫폼 API 키
# INSTAGRAM_ACCESS_TOKEN=
# TIKTOK_ACCESS_TOKEN=
