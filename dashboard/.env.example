# --- REST (Vercel 권장, DB 연결 이슈 없음) ---
# NEXT_PUBLIC_SUPABASE_URL=https://프로젝트ref.supabase.co
#
# 신규 Supabase: Secret keys → default 키 전체 (sb_secret_...)
# SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
#
# 구형: service_role JWT (eyJ...)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
#
# --- DB 직접 (Pooler 6543, Vercel에서 Direct db. 호스트 비권장) ---
# SUPABASE_DATABASE_URL=postgresql://postgres.ref:PW@....pooler.supabase.com:6543/postgres?sslmode=require
